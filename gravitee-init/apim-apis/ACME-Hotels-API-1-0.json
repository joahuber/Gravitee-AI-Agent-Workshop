  "plans": [
    {
      "definitionVersion": "V4",
      "flows": [
        {
          "name": "Protect Bookings",
          "enabled": true,
          "selectors": [
            {
              "type": "HTTP",
              "path": "/bookings",
              "pathOperator": "STARTS_WITH",
              "methods": []
            }
          ],
          "request": [
            {
              "name": "Block Anonymous Booking Access",
              "description": "Booking endpoints carry per-user data and are authorized via OpenFGA on the AI Agent (JWT) plan. Deny all keyless access to /bookings so the unauthenticated plan cannot read or modify bookings.",
              "enabled": true,
              "policy": "policy-interrupt",
              "configuration": {
                "errorKey": "BOOKINGS_REQUIRE_AUTHENTICATION",
                "variables": [],
                "scope": "REQUEST",
                "message": "Access denied: booking endpoints require an authenticated, delegated access token issued to the AI Agent on behalf of a user.",
                "statusCode": 403
              }
            }
          ],
          "response": [],
          "subscribe": [],
          "publish": [],
          "entrypointConnect": [],
          "interact": [],
          "tags": []
        }
      ],
