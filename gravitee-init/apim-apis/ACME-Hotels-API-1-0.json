          "interact": [],
          "tags": []
        }
      ],
      "name": "AI Agent",
      "description": "Restricted access, for AI Agents.",
      "security": {
        "type": "JWT",
        "configuration": {
          "signature": "RSA_RS256",
          "publicKeyResolver": "JWKS_URL",
          "resolverParameter": "http://gio-am-gateway:8092/gravitee/oidc/.well-known/jwks.json",
          "connectTimeout": 2000,
          "requestTimeout": 2000,
          "followRedirects": false,
          "useSystemProxy": false,
          "extractClaims": true,
          "propagateAuthHeader": true,
          "userClaim": "sub",
          "confirmationMethodValidation": {
            "ignoreMissing": false,
            "certificateBoundThumbprint": {
              "enabled": false,
              "extractCertificateFromHeader": false,
              "headerName": "ssl-client-cert"
            }
          },
          "tokenTypValidation": {
            "enabled": false,
            "ignoreMissing": false,
            "expectedValues": [
              "JWT"
            ],
            "ignoreCase": false
          },
          "revocationCheck": {
            "enabled": false,
            "revocationClaim": "jti",
            "refreshInterval": 300,
            "connectTimeout": 2000,
            "requestTimeout": 2000,
            "followRedirects": false,
            "useSystemProxy": false,
            "auth": {
              "type": "none"
            }
          }
        }
      },
      "mode": "STANDARD",
      "characteristics": [],
