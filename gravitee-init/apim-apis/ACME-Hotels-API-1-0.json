    },
    {
      "definitionVersion": "V4",
      "flows": [
        {
          "name": "Bookings Management",
          "enabled": true,
          "selectors": [
            {
              "type": "HTTP",
              "path": "/bookings",
              "pathOperator": "STARTS_WITH",
              "methods": []
            }
          ],
          "request": [
            {
              "name": "Transform Headers",
              "description": "Extract User Email from JWT to push a custom header to the backend.",
              "enabled": true,
              "policy": "transform-headers",
              "configuration": {
                "whitelistHeaders": [],
                "addHeaders": [
                  {
                    "name": "X-User-Email",
                    "value": "{#context.attributes['jwt.claims']['email']}"
                  }
                ],
                "scope": "REQUEST",
                "removeHeaders": []
              },
              "condition": "{#context.attributes['jwt.claims']['email'] != null}"
            },
            {
              "name": "FGA Write Authorization",
              "description": "Authorize booking modifications (updateBooking/cancelBooking) via OpenFGA can_modify/can_cancel before they reach the backend.",
              "enabled": true,
              "policy": "groovy",
              "configuration": {
                "scope": "REQUEST",
                "readContent": false,
                "overrideContent": false,
                "script": "import groovy.json.JsonSlurper\nimport groovy.json.JsonOutput\nimport io.gravitee.policy.groovy.PolicyResult.State\n\n// Authorize the write based on the operation invoked: PATCH (updateBooking) needs\n// can_modify, DELETE (cancelBooking) needs can_cancel. The accounting role can read\n// every booking but holds neither relation, so it is rejected here; only the guest\n// (owner) or a hotel admin passes.\ndef path = request.path\nif (path.endsWith('/')) { path = path.substring(0, path.length() - 1) }\ndef bookingId = path.substring(path.lastIndexOf('/') + 1)\ndef action = request.method == 'DELETE' ? 'can_cancel' : 'can_modify'\ndef userEmail = context.attributes['jwt.claims']['email']\n\ntry {\n    // Step 1: Get Bearer token via client_credentials\n    def tokenUrl = new URL('http://gio-am-gateway:8092/gravitee/oauth/token')\n    def tokenConn = tokenUrl.openConnection()\n    tokenConn.setRequestMethod('POST')\n    tokenConn.setRequestProperty('Content-Type', 'application/x-www-form-urlencoded')\n    tokenConn.setRequestProperty('Authorization', 'Basic aG90ZWwtbWNwOmhvdGVsLW1jcA==')\n    tokenConn.setDoOutput(true)\n    tokenConn.setConnectTimeout(5000)\n    tokenConn.setReadTimeout(5000)\n    tokenConn.getOutputStream().write('grant_type=client_credentials'.getBytes('UTF-8'))\n    tokenConn.getOutputStream().flush()\n    tokenConn.getOutputStream().close()\n    def tokenReader = new java.io.BufferedReader(new java.io.InputStreamReader(tokenConn.getInputStream()))\n    def tokenSb = new StringBuilder()\n    def tokenLine\n    while ((tokenLine = tokenReader.readLine()) != null) { tokenSb.append(tokenLine) }\n    tokenReader.close()\n    tokenConn.disconnect()\n    def bearerToken = new JsonSlurper().parseText(tokenSb.toString()).access_token\n\n    // Step 2: Evaluate the action against OpenFGA via the AuthZen endpoint\n    def payload = JsonOutput.toJson([\n        subject: [type: 'user', id: userEmail],\n        resource: [type: 'booking', id: bookingId],\n        action: [name: action]\n    ])\n    def evalUrl = new URL('http://gio-am-gateway:8092/gravitee/access/v1/evaluation')\n    def conn = evalUrl.openConnection()\n    conn.setRequestMethod('POST')\n    conn.setRequestProperty('Content-Type', 'application/json')\n    conn.setRequestProperty('Authorization', 'Bearer ' + bearerToken)\n    conn.setDoOutput(true)\n    conn.setConnectTimeout(5000)\n    conn.setReadTimeout(5000)\n    conn.getOutputStream().write(payload.getBytes('UTF-8'))\n    conn.getOutputStream().flush()\n    conn.getOutputStream().close()\n    def reader = new java.io.BufferedReader(new java.io.InputStreamReader(conn.getInputStream()))\n    def sb = new StringBuilder()\n    def line\n    while ((line = reader.readLine()) != null) { sb.append(line) }\n    reader.close()\n    conn.disconnect()\n    def decision = new JsonSlurper().parseText(sb.toString()).decision\n\n    if (decision != true) {\n        result.state = State.FAILURE\n        result.code = 403\n        result.error = JsonOutput.toJson([error: 'Not allowed to ' + action + ' this booking', booking: bookingId])\n        result.contentType = 'application/json'\n    }\n} catch (Exception e) {\n    // Fail closed: deny the write if the authorization decision cannot be obtained.\n    result.state = State.FAILURE\n    result.code = 403\n    result.error = JsonOutput.toJson([error: 'Authorization check failed'])\n    result.contentType = 'application/json'\n}"
              },
              "condition": "{(#request.method == 'PATCH' || #request.method == 'DELETE') && #request.path.startsWith('/hotels/bookings/')}"
            },
            {
              "name": "Self-Booking Authorization",
              "description": "createBooking may only be used for the caller themselves: the guest_email in the body must match the authenticated user's email. Blocks creating bookings on behalf of others.",
              "enabled": true,
              "policy": "groovy",
              "configuration": {
                "scope": "REQUEST",
                "readContent": true,
                "overrideContent": false,
                "script": "import groovy.json.JsonSlurper\nimport groovy.json.JsonOutput\nimport io.gravitee.policy.groovy.PolicyResult.State\n\n// createBooking (POST) may only be performed for the authenticated user: the\n// booking's guest_email must equal the caller's email. This stops anyone -- the\n// accounting role included -- from creating bookings on behalf of someone else.\ndef userEmail = context.attributes['jwt.claims']['email']\ntry {\n    def parsed = new JsonSlurper().parseText(request.content)\n    def body = parsed?.bodySchema != null ? parsed.bodySchema : parsed\n    def guestEmail = body?.guest_email\n    if (userEmail == null || guestEmail == null || guestEmail.toString().toLowerCase() != userEmail.toString().toLowerCase()) {\n        result.state = State.FAILURE\n        result.code = 403\n        result.error = JsonOutput.toJson([error: 'You can only create bookings for yourself', guest_email: guestEmail])\n        result.contentType = 'application/json'\n    }\n} catch (Exception e) {\n    result.state = State.FAILURE\n    result.code = 403\n    result.error = JsonOutput.toJson([error: 'Booking authorization failed'])\n    result.contentType = 'application/json'\n}"
              },
              "condition": "{#request.method == 'POST' && (#request.path == '/hotels/bookings' || #request.path == '/hotels/bookings/')}"
            }
          ],
          "response": [
            {
              "name": "FGA Response Filter",
              "description": "Filter bookings based on OpenFGA can_view authorization",
              "enabled": true,
              "policy": "groovy",
              "configuration": {
                "scope": "REQUEST",
                "readContent": true,
                "overrideContent": true,
                "script": "import groovy.json.JsonSlurper\nimport groovy.json.JsonOutput\n\nif (response.status == 200 && response.content != null) {\n    def slurper = new JsonSlurper()\n    def body = slurper.parseText(response.content)\n\n    if (body instanceof List && !body.isEmpty()) {\n        def userEmail = context.attributes['jwt.claims']['email']\n\n        // Step 1: Get Bearer token via client_credentials\n        def tokenUrl = new URL('http://gio-am-gateway:8092/gravitee/oauth/token')\n        def tokenConn = tokenUrl.openConnection()\n        tokenConn.setRequestMethod('POST')\n        tokenConn.setRequestProperty('Content-Type', 'application/x-www-form-urlencoded')\n        tokenConn.setRequestProperty('Authorization', 'Basic aG90ZWwtbWNwOmhvdGVsLW1jcA==')\n        tokenConn.setDoOutput(true)\n        tokenConn.setConnectTimeout(5000)\n        tokenConn.setReadTimeout(5000)\n        def tokenBody = 'grant_type=client_credentials'.getBytes('UTF-8')\n        tokenConn.getOutputStream().write(tokenBody)\n        tokenConn.getOutputStream().flush()\n        tokenConn.getOutputStream().close()\n\n        def tokenReader = new java.io.BufferedReader(new java.io.InputStreamReader(tokenConn.getInputStream()))\n        def tokenSb = new StringBuilder()\n        def tokenLine\n        while ((tokenLine = tokenReader.readLine()) != null) { tokenSb.append(tokenLine) }\n        tokenReader.close()\n        tokenConn.disconnect()\n\n        def tokenResult = slurper.parseText(tokenSb.toString())\n        def bearerToken = tokenResult.access_token\n\n        // Step 2: Check each booking against AuthZen\n        def filtered = body.findAll { booking ->\n            try {\n                def payload = JsonOutput.toJson([\n                    subject: [type: 'user', id: userEmail],\n                    resource: [type: 'booking', id: booking.id],\n                    action: [name: 'can_view']\n                ])\n\n                def evalUrl = new URL('http://gio-am-gateway:8092/gravitee/access/v1/evaluation')\n                def conn = evalUrl.openConnection()\n                conn.setRequestMethod('POST')\n                conn.setRequestProperty('Content-Type', 'application/json')\n                conn.setRequestProperty('Authorization', 'Bearer ' + bearerToken)\n                conn.setDoOutput(true)\n                conn.setConnectTimeout(5000)\n                conn.setReadTimeout(5000)\n                conn.getOutputStream().write(payload.getBytes('UTF-8'))\n                conn.getOutputStream().flush()\n                conn.getOutputStream().close()\n\n                def reader = new java.io.BufferedReader(new java.io.InputStreamReader(conn.getInputStream()))\n                def sb = new StringBuilder()\n                def line\n                while ((line = reader.readLine()) != null) { sb.append(line) }\n                reader.close()\n                conn.disconnect()\n\n                def result = slurper.parseText(sb.toString())\n                return result.decision == true\n            } catch (Exception e) {\n                return false\n            }\n        }\n\n        return JsonOutput.toJson(filtered)\n    }\n}\nreturn response.content"
              },
              "condition": "{#request.method == 'GET' && (#request.path == '/hotels/bookings' || #request.path.startsWith('/hotels/bookings/'))}"
            }
          ],
          "subscribe": [],
          "publish": [],
          "entrypointConnect": [],
          "interact": [],
          "tags": []
        },
        {
          "name": "All",
          "enabled": true,
          "selectors": [
            {
              "type": "HTTP",
