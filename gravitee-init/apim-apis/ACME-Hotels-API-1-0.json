              "specification": "[\n  {\n    \"operation\": \"shift\",\n    \"spec\": {\n      \"jsonrpc\": \"jsonrpc\",\n      \"id\": \"id\",\n      \"result\": {\n        \"content\": \"result.content\",\n        \"error\": {\n          \"#true\": \"result.isError\"\n        }\n      }\n    }\n  },\n  {\n    \"operation\": \"modify-overwrite-beta\",\n    \"spec\": {\n      \"result\": {\n        \"isError\": \"=toBoolean\"\n      }\n    }\n  }\n]"
